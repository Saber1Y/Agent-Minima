# BTL Runtime API
BTL_ENDPOINT=https://api.badtheorylabs.com/v1/chat/completions
BTL_API_KEY=gw_...
BTL_MODEL=deepseek-chat-v3

# Wallet (Base Sepolia)
RPC_BASE_SEPOLIA=https://sepolia.base.org
DEPLOYER_PRIVATE_KEY=0x...
AGENT_PRIVATE_KEY=0x...

# Deployed contract addresses
AGENT_ACCOUNT_ADDRESS=0x...
TARGET_CONTRACT=0x...
TARGET_DATA=0x...

# User ZK inputs
USER_AGE=25
USER_TOKEN_BALANCE=500
USER_ADDRESS=42

# Privy (wallet connect)
# Create a free app at https://privy.io and copy the App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# Proving microservice (set to deploy proving service URL)
# Omit or leave empty to run proving locally
PROVER_URL=

# Vercel KV (set in Vercel dashboard for persistence)
# Omit or leave empty for in-memory storage (local dev)
KV_URL=

# BaseScan API (optional, for contract verification)
BASESCAN_API_KEY=
